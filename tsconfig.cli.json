{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist/cli",
    "rootDir": "./src/cli",
    "declaration": false
  },
  "include": ["src/cli/**/*"],
  "exclude": ["node_modules"]
}
