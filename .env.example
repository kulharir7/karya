# Karya Environment Variables
# Copy this to .env and fill in your values

# LLM Provider Configuration
LLM_PROVIDER=custom
LLM_MODEL=qwen3-coder:480b

# Custom Provider (ollama-cloud, etc.)
CUSTOM_PROVIDER_NAME=ollama-cloud
LLM_BASE_URL=https://ollama.com/v1
LLM_API_KEY=your-api-key-here

# Optional: Standard Provider API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Stagehand (Browser Automation)
STAGEHAND_MODEL=gpt-4o
STAGEHAND_PROVIDER=openai
STAGEHAND_API_KEY=

# Server
PORT=3000
WS_PORT=3002
