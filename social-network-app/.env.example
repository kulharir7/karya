# .env.example - fill in the values before running the app

# PostgreSQL credentials (used by both backend and docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=social_network

# JWT secrets
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret

# AWS S3 configuration (for avatar / post image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=us-east-1

# SendGrid (email notifications)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=no-reply@yourdomain.com

# OAuth (optional – you can enable Google/Facebook later)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
