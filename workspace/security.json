{
  "enabled": true,
  "blockedTools": [],
  "blockedCommands": [
    "^format\\s",
    "^fdisk\\s",
    "^diskpart",
    "rm\\s+-rf\\s+/\\s*$",
    "rm\\s+-rf\\s+/\\*",
    "del\\s+/s\\s+/q\\s+C:\\\\\\s*$",
    "Remove-Item\\s+-Recurse.*C:\\\\Windows",
    "Remove-Item\\s+-Recurse.*C:\\\\Program",
    "^reg\\s+delete",
    "^reg\\s+add.*HKLM",
    "^net\\s+user\\s+.*\\/add",
    "^net\\s+localgroup\\s+admin",
    "powershell.*-[Ee]nc\\s",
    "powershell.*-[Ee]ncodedCommand",
    "curl.*\\|\\s*sh",
    "curl.*\\|\\s*bash",
    "wget.*\\|\\s*sh",
    "wget.*\\|\\s*bash",
    "iex\\s*\\(.*Net\\.WebClient",
    "^bcdedit",
    "^bootrec",
    "mimikatz",
    "credential.*dump"
  ],
  "blockedPaths": [
    "C:\\Windows",
    "C:\\Program Files",
    "C:\\Program Files (x86)",
    "C:\\ProgramData",
    "C:\\Recovery",
    "C:\\$Recycle.Bin",
    "/etc/passwd",
    "/etc/shadow",
    "/usr/bin",
    "/usr/sbin",
    "/boot",
    "/proc",
    "/sys"
  ],
  "allowedPaths": [],
  "restrictToAllowed": false,
  "rateLimits": {
    "shell-execute": 15,
    "file-write": 40,
    "file-delete": 5,
    "file-move": 20,
    "kill-process": 5,
    "git-push": 5,
    "git-commit": 10,
    "api-call": 20,
    "system-screenshot": 10,
    "code-execute": 15
  },
  "maxShellTimeoutSeconds": 60
}